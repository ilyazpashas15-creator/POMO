{
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "typescript.validate.enable": true,
  "javascript.validate.enable": true,
  "files.watcherExclude": {
    "**/node_modules/**": true
  }
}